# Pick a backend. ollama for local, gemini for cloud.
LLM_BACKEND=ollama

# Ollama config. Install Ollama from https://ollama.com first, then pull models.
# Recommended sweet spot for a Mac, qwen2.5:7b or llama3.1:8b.
# For higher reasoning quality at slower speed, try qwen2.5:14b or llama3.1:70b.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_RESEARCHER_MODEL=qwen2.5:7b
OLLAMA_EDITOR_MODEL=qwen2.5:7b

# Gemini config. Only needed if LLM_BACKEND=gemini.
# Get a free API key at https://aistudio.google.com/apikey
# Free tier is 20 requests per day per model, enable billing for production.
GOOGLE_API_KEY=
GEMINI_RESEARCHER_MODEL=gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EDITOR_MODEL=gemini-2.5-flash

# Lookback window for the agents to research over
LOOKBACK_WINDOW=past 7 days

# Slack delivery, recommended primary channel.
# Create an incoming webhook at https://api.slack.com/messaging/webhooks
# Paste the webhook URL below. The brief auto posts to the channel the webhook is bound to.
SLACK_WEBHOOK_URL=
SLACK_USERNAME=LuckyHands Intel Daily
SLACK_ICON_EMOJI=:newspaper:
# SLACK_CHANNEL is only needed if your webhook supports channel override, usually leave blank.
SLACK_CHANNEL=

# Email send config, only used when you run `python run.py send`. Phase 2 path.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SENDER_NAME=LuckyHands Intel Daily
SENDER_EMAIL=
RECIPIENT_EMAIL=daniel@luckyhands.com
