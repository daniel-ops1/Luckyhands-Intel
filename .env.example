# =============================================================================
# LuckyHands Intel Daily, .env template
#
# Copy this to .env and fill in the marked values. Everything is free-tier and
# requires no credit card.
# =============================================================================

# -----------------------------------------------------------------------------
# Backend selection
# -----------------------------------------------------------------------------

# Default backend if RESEARCHER_BACKEND / EDITOR_BACKEND below are unset.
# Valid values: ollama, gemini
LLM_BACKEND=ollama

# Per-agent backend override. Recommended:
#   RESEARCHER_BACKEND=ollama  (local, no rate limit, handles tool-call loops)
#   EDITOR_BACKEND=gemini      (much stronger instruction following on the template)
RESEARCHER_BACKEND=ollama
EDITOR_BACKEND=gemini

# -----------------------------------------------------------------------------
# Ollama (local LLM)
# -----------------------------------------------------------------------------

# Install Ollama from https://ollama.com, then run `ollama serve` to start.
OLLAMA_BASE_URL=http://localhost:11434

# Pull with `ollama pull qwen2.5:14b`. The qwen-intel name below points to a
# tuned Modelfile in this repo with num_ctx bumped to 16384.
# 14B fits on 16GB+ unified memory. For 32GB+ try qwen2.5:32b or gemma3:27b.
OLLAMA_RESEARCHER_MODEL=qwen-intel
OLLAMA_EDITOR_MODEL=qwen-intel

# -----------------------------------------------------------------------------
# Google Gemini (cloud, free tier)
# -----------------------------------------------------------------------------

# Get a free API key at https://aistudio.google.com/apikey (no credit card).
# Free tier: 20 RPD project-wide across all Gemini models. The pipeline uses
# ~12 calls per run, fits one daily run with headroom.
GOOGLE_API_KEY=

# Model selection. Editor uses Flash for strong template adherence.
# Verify and grounding default to Flash-Lite (override via VERIFY_MODEL /
# GROUNDING_MODEL below).
GEMINI_RESEARCHER_MODEL=gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EDITOR_MODEL=gemini-2.5-flash

# Override the grounding model (used by grounding.py).
# Default is gemini-2.5-flash-lite.
# GROUNDING_MODEL=gemini-2.5-flash-lite

# Override the verify-gate model (used by verify_brief.py).
# Default is gemini-2.5-flash-lite.
# VERIFY_MODEL=gemini-2.5-flash-lite

# Override the corrections model used by intel_publish.py improve loop.
# Default is gemini-2.5-flash.
# CORRECTION_MODEL=gemini-2.5-flash

# -----------------------------------------------------------------------------
# Search backends (used by Ollama researchers)
# -----------------------------------------------------------------------------

# Tavily, 1,000 queries/mo free. Primary search backend. Setup: 2 minutes at
# https://app.tavily.com/ with Google or email login.
TAVILY_API_KEY=

# Exa, neural semantic search. Signup credits, no card. Setup: 2 minutes at
# https://dashboard.exa.ai/
EXA_API_KEY=

# DuckDuckGo Lite is the final fallback. Throttle in seconds between calls to
# avoid the 202 anomaly rate limit. Leave at 8.
WEB_SEARCH_MIN_INTERVAL_S=8

# Optional, override monthly caps used by the budget ledger in tools.py.
# TAVILY_MONTHLY_CAP=1000
# EXA_MONTHLY_CAP=1500

# -----------------------------------------------------------------------------
# Primary source APIs
# -----------------------------------------------------------------------------

# LegiScan, 30,000 queries/mo free. Used to pull sweepstakes-relevant bills
# across all 50 states. Signup: https://legiscan.com/legiscan with email.
LEGISCAN_API_KEY=

# CourtListener REST API v4, 125 queries/day free. Federal court filings.
# Signup: https://www.courtlistener.com/help/api/rest/
# COURTLISTENER_DAILY_CAP=125
COURTLISTENER_API_TOKEN=

# -----------------------------------------------------------------------------
# Slack delivery
# -----------------------------------------------------------------------------

# Create an Incoming Webhook at https://api.slack.com/messaging/webhooks
# The brief auto-posts to the channel bound to the webhook.
SLACK_WEBHOOK_URL=
SLACK_USERNAME=LuckyHands Intel Daily
SLACK_ICON_EMOJI=:newspaper:
# SLACK_CHANNEL only needed if your webhook supports channel override.
SLACK_CHANNEL=

# -----------------------------------------------------------------------------
# Email fallback (only used by `python run.py send`, not the default flow)
# -----------------------------------------------------------------------------

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SENDER_NAME=LuckyHands Intel Daily
SENDER_EMAIL=
RECIPIENT_EMAIL=

# -----------------------------------------------------------------------------
# Runtime flags (set per invocation, not persisted)
# -----------------------------------------------------------------------------

# LOOKBACK_WINDOW=past 7 days
# INTEL_DAILY_NO_SLACK=1          Skip the Slack post even when the verify gate clears.
# INTEL_DAILY_NO_BROWSER=1        Do not open the rendered HTML in a browser.
# INTEL_DAILY_SKIP_VERIFY=1       Bypass the verify gate (e.g. when intel_publish.py runs it instead).
# INTEL_DAILY_ISSUE_OVERRIDE=0    Force a specific issue number without bumping the persistent counter.
# LLM_TIMEOUT_S=1200              Override the LiteLLM timeout for Ollama calls.
# INTEL_DAILY_FORCE_SENTIMENT=1   Force the Friday-only Reddit + App Store pull on any day.
